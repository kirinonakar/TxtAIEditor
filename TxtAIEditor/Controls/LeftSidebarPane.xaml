<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TxtAIEditor.Controls.LeftSidebarPane"
    x:Name="RootLeftSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TxtAIEditor.Controls"
    xmlns:models="using:TxtAIEditor.Core.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:LocalizationBridge x:Key="LocBridge"/>
        <Style x:Key="FlatActivityButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                            <!-- Left active indicator bar -->
                             <Rectangle x:Name="ActiveIndicator" 
                                       Width="3" 
                                       HorizontalAlignment="Left" 
                                       Fill="{ThemeResource AccentTextFillColorPrimaryBrush}" 
                                       Visibility="Collapsed"
                                       VerticalAlignment="Stretch"
                                       Margin="0,6,0,6"/>
                            
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              AutomationProperties.AccessibilityView="Raw"/>
                            
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundBaseMediumBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SidebarBackgroundBrush}"/>
                                            <Setter Target="ActiveIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SidebarBackgroundBrush}"/>
                                            <Setter Target="ActiveIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SystemControlBackgroundBaseMediumBrush}"/>
                                            <Setter Target="ActiveIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- A. Left Panel (File Explorer & Favorites & Recent Files & Search & Git & Snippets) -->
    <Grid x:Name="SidebarRoot" Background="{ThemeResource SidebarBackgroundBrush}" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="38"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{ThemeResource ActivityBarBackgroundBrush}" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Padding="0,4,0,4" Spacing="0">
                <ToggleButton x:Name="ExplorerActivityButton" Tag="0" IsChecked="True" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE8B7;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="FavoritesActivityButton" Tag="1" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE734;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="RecentActivityButton" Tag="2" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE81C;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="SearchActivityButton" Tag="3" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE721;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="TocActivityButton" Tag="6" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE169;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="GitActivityButton" Tag="4" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE139;" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="SnippetsActivityButton" Tag="5" Style="{StaticResource FlatActivityButtonStyle}" Click="OnLeftActivityClick">
                    <FontIcon Glyph="&#xE943;" FontSize="13"/>
                </ToggleButton>
            </StackPanel>
        </Border>
    
                    <Grid Grid.Column="1">
                        
                        <!-- Tab 1: File Explorer -->
                        <Grid x:Name="ExplorerSidebarPage">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="10" Spacing="8">
                                    <Grid ColumnSpacing="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                    <Button x:Name="ExplorerUpButton" Click="OnExplorerUpClick" ToolTipService.ToolTip="상위 폴더" Padding="0" Width="28" MinWidth="28" Height="28">
                                            <FontIcon Glyph="&#xE74A;" FontSize="10"/>
                                        </Button>
                                    <Button x:Name="ExplorerSelectFolderButton" Grid.Column="1" Click="OnSelectFolderClick" ToolTipService.ToolTip="폴더 선택..." AutomationProperties.Name="폴더 선택..." Padding="0" Width="28" MinWidth="28" Height="28">
                                            <FontIcon Glyph="&#xED25;" FontSize="10"/>
                                        </Button>
                                    <Button x:Name="ExplorerCreateFolderButton" Grid.Column="2" Click="OnCreateFolderClick" ToolTipService.ToolTip="새 폴더" Padding="0" Width="28" MinWidth="28" Height="28">
                                            <FontIcon Glyph="&#xE710;" FontSize="10"/>
                                        </Button>
                                    <Button x:Name="ExplorerRefreshButton" Grid.Column="3" Click="OnRefreshClick" ToolTipService.ToolTip="새로고침" Padding="0" Width="28" MinWidth="28" Height="28">
                                            <FontIcon Glyph="&#xE72C;" FontSize="10"/>
                                        </Button>
                                    <Button x:Name="ExplorerSortButton" Grid.Column="4" Click="OnSortClick" ToolTipService.ToolTip="이름순 정렬" Padding="0" Width="28" MinWidth="28" Height="28">
                                            <FontIcon Glyph="&#xE8CB;" FontSize="10"/>
                                        </Button>
                                    <Button x:Name="ExplorerOpenInWindowsButton" Grid.Column="6" Click="OnOpenInWindowsExplorerClick" ToolTipService.ToolTip="Windows 탐색기에서 열기" AutomationProperties.Name="Windows 탐색기에서 열기" Padding="0" Width="28" MinWidth="28" Height="28">
                                            <FontIcon Glyph="&#xE8DA;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ExplorerStatusText" Text="폴더를 선택하세요." FontSize="11" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ExplorerTreeModeButton" Grid.Column="1" Click="OnExplorerTreeModeClick" ToolTipService.ToolTip="트리 모드" AutomationProperties.Name="트리 모드" Padding="0" Width="28" MinWidth="28" Height="28" VerticalAlignment="Top">
                                            <FontIcon Glyph="&#xE8A4;" FontSize="10"/>
                                        </ToggleButton>
                                        <Button x:Name="ExplorerHomeButton" Grid.Column="2" Click="OnExplorerHomeClick" ToolTipService.ToolTip="홈 폴더로 이동" AutomationProperties.Name="홈 폴더로 이동" Padding="0" Width="28" MinWidth="28" Height="28" VerticalAlignment="Top">
                                            <FontIcon Glyph="&#xE80F;" FontSize="10"/>
                                        </Button>
                                    </Grid>

                                    <Grid x:Name="ExplorerFilterPanel">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="10" Margin="8,0,6,0"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBox x:Name="ExplorerFilterBox"
                                                 Grid.Column="1"
                                                 PlaceholderText="파일명 필터 (하위 폴더 포함)..."
                                                 FontSize="11"
                                                 Height="28"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,6,4,0"
                                                 BorderThickness="0,0,0,1"
                                                 Background="Transparent"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollMode="Disabled"
                                                 IsSpellCheckEnabled="False"
                                                 IsTextPredictionEnabled="False"
                                                 TextChanged="OnExplorerFilterTextChanged"/>
                                    </Grid>
                                </StackPanel>
                                <ListView x:Name="FileListView" Grid.Row="1" Margin="0,5,0,5" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnFileListViewItemClick" AllowDrop="True" DragOver="OnFileListViewDragOver" Drop="OnFileListViewDrop">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,3,0,3" RightTapped="OnFileListViewItemRightTapped" AllowDrop="True" DragOver="OnFileListViewItemDragOver" Drop="OnFileListViewItemDrop">
                                                <Grid.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="즐겨찾기에 추가" Icon="Favorite" Click="OnAddFileToFavoritesClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem Text="폴더를 즐겨찾기에 추가" Icon="OutlineStar" Click="OnAddFolderToFavoritesClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem x:Name="ExplorerInsertMarkdownImageMenuItem" Text="마크다운 삽입" Icon="Pictures" Click="OnInsertMarkdownImageClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem x:Name="ExplorerOpenExternalViewerMenuItem" Text="외부 뷰어로 열기" Click="OnOpenExternalViewerClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE8A7;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Name="ExplorerOpenWithDefaultProgramMenuItem" Text="기본 프로그램으로 열기" Click="OnOpenWithDefaultProgramClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE163;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Name="ExplorerExtractArchiveToFolderMenuItem" Text="폴더에 풀기" Click="OnExtractArchiveToFolderClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Name="ExplorerCompressFolderToZipMenuItem" Text="" Click="OnCompressFolderToZipClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE7B8;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Name="ExplorerCompressFolderToSevenZipMenuItem" Text="" Click="OnCompressFolderToSevenZipClick" Tag="{Binding}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE7B8;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutSeparator/>
                                                        <MenuFlyoutItem x:Name="ExplorerCopyFileNameMenuItem" Text="파일이름 복사" Icon="Copy" Click="OnCopyFileNameClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem x:Name="ExplorerCopyFilePathMenuItem" Text="경로 복사" Icon="Link" Click="OnCopyFilePathClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem x:Name="ExplorerCopyFolderPathMenuItem" Text="폴더 경로 복사" Icon="Link" Click="OnCopyFolderPathClick" Tag="{Binding}"/>
                                                        <MenuFlyoutSeparator/>
                                                        <MenuFlyoutItem x:Name="ExplorerRenameMenuItem" Text="이름 바꾸기" Icon="Rename" Click="OnRenameClick" Tag="{Binding}"/>
                                                        <MenuFlyoutItem x:Name="ExplorerDeleteMenuItem" Text="삭제" Icon="Delete" Click="OnDeleteClick" Tag="{Binding}"/>
                                                    </MenuFlyout>
                                                </Grid.ContextFlyout>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <FontIcon.Foreground>
                                                        <SolidColorBrush Color="{Binding IconColor}"/>
                                                    </FontIcon.Foreground>
                                                </FontIcon>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="{Binding ForegroundColor}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Path}"/>
                                                    <TextBlock Text="{Binding SubPath}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis" Visibility="{Binding SubPathVisibility}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding GitBadge}" Foreground="{Binding ForegroundColor}" FontSize="10" FontWeight="Bold" Margin="5,0,8,0" VerticalAlignment="Center" Visibility="{Binding GitBadgeVisibility}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TreeView x:Name="ExplorerTreeView"
                                          Grid.Row="1"
                                          Margin="0,5,0,5"
                                          Visibility="Collapsed"
                                          SelectionMode="Single"
                                          AllowDrop="True"
                                          DragOver="OnExplorerTreeDragOver"
                                          Drop="OnExplorerTreeDrop"
                                          Expanding="OnExplorerTreeExpanding"
                                          ItemInvoked="OnExplorerTreeItemInvoked">
                                    <TreeView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,3,8,3" ToolTipService.ToolTip="{Binding Content.Path}" RightTapped="OnFileListViewItemRightTapped">
                                                <Grid.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="즐겨찾기에 추가" Icon="Favorite" Click="OnAddFileToFavoritesClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutItem Text="폴더를 즐겨찾기에 추가" Icon="OutlineStar" Click="OnAddFolderToFavoritesClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutItem Text="마크다운 삽입" Icon="Pictures" Click="OnInsertMarkdownImageClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutItem Text="외부 뷰어로 열기" Click="OnOpenExternalViewerClick" Tag="{Binding Content}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE8A7;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="기본 프로그램으로 열기" Click="OnOpenWithDefaultProgramClick" Tag="{Binding Content}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE163;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="폴더에 풀기" Click="OnExtractArchiveToFolderClick" Tag="{Binding Content}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="" Click="OnCompressFolderToZipClick" Tag="{Binding Content}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE7B8;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="" Click="OnCompressFolderToSevenZipClick" Tag="{Binding Content}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE7B8;" FontSize="12"/>
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutSeparator/>
                                                        <MenuFlyoutItem Text="파일이름 복사" Icon="Copy" Click="OnCopyFileNameClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutItem Text="경로 복사" Icon="Link" Click="OnCopyFilePathClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutItem Text="폴더 경로 복사" Icon="Link" Click="OnCopyFolderPathClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutSeparator/>
                                                        <MenuFlyoutItem Text="이름 바꾸기" Icon="Rename" Click="OnRenameClick" Tag="{Binding Content}"/>
                                                        <MenuFlyoutItem Text="삭제" Icon="Delete" Click="OnDeleteClick" Tag="{Binding Content}"/>
                                                    </MenuFlyout>
                                                </Grid.ContextFlyout>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="{Binding Content.IconGlyph}" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <FontIcon.Foreground>
                                                        <SolidColorBrush Color="{Binding Content.IconColor}"/>
                                                    </FontIcon.Foreground>
                                                </FontIcon>
                                                <TextBlock Grid.Column="1" Text="{Binding Content.Name}" Foreground="{Binding Content.ForegroundColor}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Content.GitBadge}" Foreground="{Binding Content.ForegroundColor}" FontSize="10" FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="{Binding Content.GitBadgeVisibility}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                        </Grid>
    
                        <!-- Tab 2: Favorites -->
                        <Grid x:Name="FavoritesSidebarPage" Padding="0,10,0,10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" x:Name="FavoritesHeaderText" Text="즐겨찾기 목록" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="10,0,0,8"/>
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="FavoritesFileTab" Grid.Column="0" Content="파일" FontSize="13" Height="30" Padding="10,0" Margin="15,0,0,0" IsChecked="True" Click="OnFavoritesTabClick"/>
                                    <ToggleButton x:Name="FavoritesFolderTab" Grid.Column="1" Content="폴더" FontSize="13" Height="30" Padding="10,0" Margin="6,0,0,0" Click="OnFavoritesTabClick"/>
                                </Grid>
                                <ListView x:Name="FavoritesListView" Grid.Row="2" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnFavoriteItemClick">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4,0,4" ToolTipService.ToolTip="{Binding Path}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <FontIcon.Foreground>
                                                        <SolidColorBrush Color="{Binding IconColor}"/>
                                                    </FontIcon.Foreground>
                                                </FontIcon>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" x:Name="FavoritePinButton" Background="Transparent" BorderBrush="Transparent" Padding="3" VerticalAlignment="Center" Opacity="{Binding PinOpacity}" Click="OnFavoritePinClick" Tag="{Binding}" ToolTipService.ToolTip="고정">
                                                    <FontIcon Glyph="&#xE718;" FontSize="10"/>
                                                </Button>
                                                <Button Grid.Column="3" Background="Transparent" BorderBrush="Transparent" Click="OnRemoveFavoriteClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" ToolTipService.ToolTip="즐겨찾기에서 제거">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="10"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                        </Grid>
    
                        <!-- Tab 3: Recent Files -->
                        <Grid x:Name="RecentSidebarPage" Padding="0,10,0,10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="RecentFilesHeaderText" Grid.Row="0" Text="최근 파일" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="10,0,0,8"/>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="RecentFileTab" Grid.Column="0" Content="파일" FontSize="13" Height="30" Padding="10,0" Margin="15,0,0,0" IsChecked="True" Click="OnRecentTabClick"/>
                                <ToggleButton x:Name="RecentFolderTab" Grid.Column="1" Content="폴더" FontSize="13" Height="30" Padding="10,0" Margin="6,0,0,0" Click="OnRecentTabClick"/>
                            </Grid>
                            <ListView x:Name="RecentFilesListView" Grid.Row="2" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnRecentFileItemClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4,0,4" ToolTipService.ToolTip="{Binding Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <FontIcon.Foreground>
                                                    <SolidColorBrush Color="{Binding IconColor}"/>
                                                </FontIcon.Foreground>
                                            </FontIcon>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Background="Transparent" BorderBrush="Transparent" Click="OnRemoveRecentFileClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" ToolTipService.ToolTip="최근 파일 목록에서 제거">
                                                <FontIcon Glyph="&#xE74D;" FontSize="10"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
    
                        <!-- Tab 4: Search & Replace Panel -->
                        <Grid x:Name="SearchSidebarPage" Padding="0,10,0,10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Form Inputs -->
                                    <RowDefinition Height="*"/>    <!-- Results -->
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Spacing="8" Margin="10,0,10,10">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock x:Name="SearchHeaderText" Text="폴더 전체 검색 및 바꾸기" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        <Ellipse x:Name="SearchProgressDot" Width="7" Height="7" Fill="#2FB344" Visibility="Collapsed" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox x:Name="SearchQueryInput" PlaceholderText="검색어 입력..." KeyDown="OnSearchQueryInputKeyDown" Height="32" FontSize="12" FontFamily="Segoe UI, Malgun Gothic" VerticalContentAlignment="Center" Padding="10,8,10,0" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollMode="Disabled" IsSpellCheckEnabled="False" IsTextPredictionEnabled="False"/>
                                    <TextBox x:Name="ReplaceQueryInput" PlaceholderText="바꿀 단어 입력..." Height="32" FontSize="12" FontFamily="Segoe UI, Malgun Gothic" VerticalContentAlignment="Center" Padding="10,8,10,0" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollMode="Disabled" IsSpellCheckEnabled="False" IsTextPredictionEnabled="False"/>
                                    
                                    <Grid ColumnSpacing="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton x:Name="SearchMatchCaseToggle" Content="Aa" ToolTipService.ToolTip="대소문자 구분" HorizontalAlignment="Stretch" FontSize="11"/>
                                        <ToggleButton x:Name="SearchWholeWordToggle" Content="[ab]" Grid.Column="1" ToolTipService.ToolTip="단어 단위" HorizontalAlignment="Stretch" FontSize="11"/>
                                        <ToggleButton x:Name="SearchRegexToggle" Content=".*" Grid.Column="2" ToolTipService.ToolTip="정규식 검색" HorizontalAlignment="Stretch" FontSize="11"/>
                                    </Grid>
     
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="SearchAllButton" Content="전체 검색" HorizontalAlignment="Stretch" Click="OnSearchAllFilesClick" Style="{StaticResource AccentButtonStyle}" FontSize="11"/>
                                        <Button x:Name="ReplaceAllButton" Content="모두 바꾸기" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnReplaceAllClick" FontSize="11"/>
                                    </Grid>
                                </StackPanel>
    
                                <ListView x:Name="SearchResultsList" Grid.Row="1" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnSearchResultItemClick">
                                    <ListView.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate x:DataType="models:SearchResultGroup">
                                                    <Grid Padding="8,4,8,4" Background="{ThemeResource SystemControlBackgroundListLowBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xE7C3;" FontSize="11" Margin="0,0,6,0" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" ToolTipService.ToolTip="{x:Bind Path}">
                                                            <TextBlock Text="{x:Bind FileName}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{x:Bind RelativeDirectory}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="10" Padding="6,1,6,1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind MatchCount}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListView.GroupStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:SearchResultItem">
                                            <Grid Padding="12,3,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind LineHeader}" FontWeight="SemiBold" FontSize="10" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="{x:Bind LineContent}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#xE194;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnReplaceOneClick" Tag="{x:Bind}" Padding="4" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="{x:Bind ReplaceButtonVisibility}" ToolTipService.ToolTip="{Binding Path=ReplaceOneTooltip, Source={StaticResource LocBridge}}" FontSize="11"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                        </Grid>
    
                        <!-- Tab 5: Git Panel -->
                        <Grid x:Name="GitSidebarPage" Padding="0,10,0,10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Branch Info -->
                                    <RowDefinition Height="*"/>    <!-- Changed Files -->
                                    <RowDefinition Height="Auto"/> <!-- Commit controls -->
                                    <RowDefinition Height="Auto"/> <!-- History -->
                                    <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="10,0,10,10" Spacing="5">
                                    <TextBlock x:Name="GitHeaderText" Text="Git 저장소 관리" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock x:Name="GitRepoPathText" Text="" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="GitPanelBranchText" Text="" Tag="GitNotDetected" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button x:Name="GitInitRepoButton" Grid.Column="1" Content="Git 생성" FontSize="10" Padding="6,2" Height="22" MinWidth="0" Click="OnGitInitRepoClick" ToolTipService.ToolTip="Git 저장소 생성"/>
                                        <Button x:Name="GitRefreshButton" Grid.Column="2" Width="24" MinWidth="24" Height="24" Margin="4,0,0,0" HorizontalAlignment="Right" Click="OnGitRefreshClick" Padding="0" CornerRadius="4" ToolTipService.ToolTip="새로고침">
                                            <FontIcon Glyph="&#xE72C;" FontSize="10"/>
                                        </Button>
                                    </Grid>
                                    <ComboBox x:Name="GitBranchesCombo" PlaceholderText="브랜치 목록" Height="24" FontSize="10" Padding="6,0,4,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
    
                                <ListView x:Name="GitChangedFilesList" Grid.Row="1" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnGitFileItemClick">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="3" Padding="4,1,4,1" Margin="5,0,5,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <Button Grid.Column="2" Content="{Binding ActionGlyph}" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnGitStageToggleClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" FontSize="10"/>
                                                <Button Grid.Column="3" Content="&#xE777;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderBrush="Transparent" Click="OnGitRestoreFileClick" Tag="{Binding Path}" Padding="3" VerticalAlignment="Center" ToolTipService.ToolTip="{Binding Path=GitRestoreFileTooltip, Source={StaticResource LocBridge}}" FontSize="10"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
    
                                <StackPanel Grid.Row="2" Spacing="8" Margin="10,10,10,0">
                                    <TextBox x:Name="GitCommitMessageInput" PlaceholderText="커밋 메시지 입력..." Height="32" FontSize="12" FontFamily="Segoe UI, Malgun Gothic" VerticalContentAlignment="Center" Padding="10,8,10,0" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollMode="Disabled" IsSpellCheckEnabled="False" IsTextPredictionEnabled="False"/>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="GitCommitButton" Grid.Column="0" Content="커밋 (Commit)" HorizontalAlignment="Stretch" Click="OnGitCommitClick" Style="{StaticResource AccentButtonStyle}" FontSize="11"/>
                                        <Button x:Name="GitScpButton" Grid.Column="1" Content="S/C/P" Click="OnGitScpClick" FontSize="11" Height="32" Padding="12,3" ToolTipService.ToolTip="Stage/Commit/Push"/>
                                    </Grid>
                                </StackPanel>
    
                                <StackPanel Grid.Row="3" Spacing="8" Margin="10,8,10,0">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="GitStageAllButton" Content="전체 Stage" HorizontalAlignment="Stretch" Click="OnGitStageAllClick" FontSize="11"/>
                                    <Button x:Name="GitRestoreAllButton" Grid.Column="1" Content="전체 Restore" HorizontalAlignment="Stretch" Click="OnGitRestoreAllClick" FontSize="11"/>
                                    </Grid>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <SplitButton x:Name="GitPushButton" Content="Push" HorizontalAlignment="Stretch" Click="OnGitPushClick" FontSize="11" Height="30" Padding="10,3" CornerRadius="4">
                                            <SplitButton.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem x:Name="GitPullMenuItem" Text="Pull" Click="OnGitPullClick"/>
                                                    <MenuFlyoutItem x:Name="GitRebaseMenuItem" Text="Rebase" Click="OnGitRebaseClick"/>
                                                    <MenuFlyoutItem x:Name="GitCreateBranchMenuItem" Text="Create Branch" Click="OnGitCreateBranchClick"/>
                                                    <MenuFlyoutItem x:Name="GitMergeMenuItem" Text="Merge" Click="OnGitMergeClick"/>
                                                </MenuFlyout>
                                            </SplitButton.Flyout>
                                        </SplitButton>
                                        <Button x:Name="GitRemoteButton" Grid.Column="1" Content="Remote" MinWidth="64" Height="30" Padding="10,3" HorizontalAlignment="Stretch" Click="OnGitRemoteClick" FontSize="11" IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
    
                                <StackPanel Grid.Row="4" Spacing="4" Margin="10,8,10,0">
                                    <TextBlock x:Name="GitHistoryHeader" Text="과거 기록" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <ListView x:Name="GitHistoryList" Height="160" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnGitHistoryItemClick" ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="MinHeight" Value="18"/>
                                                <Setter Property="Height" Value="18"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListViewItem">
                                                            <Grid x:Name="ItemRoot" Background="Transparent">
                                                                <VisualStateManager.VisualStateGroups>
                                                                    <VisualStateGroup x:Name="CommonStates">
                                                                        <VisualState x:Name="Normal"/>
                                                                        <VisualState x:Name="PointerOver">
                                                                            <VisualState.Setters>
                                                                                <Setter Target="ItemRoot.Background" Value="{ThemeResource SystemControlHighlightListLowBrush}"/>
                                                                            </VisualState.Setters>
                                                                        </VisualState>
                                                                        <VisualState x:Name="Pressed">
                                                                            <VisualState.Setters>
                                                                                <Setter Target="ItemRoot.Background" Value="{ThemeResource SystemControlHighlightListMediumBrush}"/>
                                                                            </VisualState.Setters>
                                                                        </VisualState>
                                                                        <VisualState x:Name="Selected">
                                                                            <VisualState.Setters>
                                                                                <Setter Target="ItemRoot.Background" Value="{ThemeResource SystemControlHighlightListAccentLowBrush}"/>
                                                                            </VisualState.Setters>
                                                                        </VisualState>
                                                                        <VisualState x:Name="SelectedUnfocused">
                                                                            <VisualState.Setters>
                                                                                <Setter Target="ItemRoot.Background" Value="{ThemeResource SystemControlHighlightListAccentLowBrush}"/>
                                                                            </VisualState.Setters>
                                                                        </VisualState>
                                                                        <VisualState x:Name="SelectedPointerOver">
                                                                            <VisualState.Setters>
                                                                                <Setter Target="ItemRoot.Background" Value="{ThemeResource SystemControlHighlightListAccentMediumBrush}"/>
                                                                            </VisualState.Setters>
                                                                        </VisualState>
                                                                        <VisualState x:Name="SelectedPressed">
                                                                            <VisualState.Setters>
                                                                                <Setter Target="ItemRoot.Background" Value="{ThemeResource SystemControlHighlightListAccentMediumBrush}"/>
                                                                            </VisualState.Setters>
                                                                        </VisualState>
                                                                    </VisualStateGroup>
                                                                </VisualStateManager.VisualStateGroups>
                                                                <ContentPresenter 
                                                                    Content="{TemplateBinding Content}"
                                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Stretch"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid local:TextBlockExtensions.GitHistoryItem="{Binding}" Padding="0"/>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                        </Grid>
    
                        <!-- Tab 6: Snippets Hub -->
                        <Grid x:Name="SnippetsSidebarPage" Padding="0,10,0,10" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="SnippetsHeaderText" Grid.Row="0" Text="코드 및 수식 템플릿" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="10,0,10,10"/>
                                <ListView x:Name="SnippetsListView" Grid.Row="1" SelectionMode="Single" DoubleTapped="OnSnippetItemDoubleTapped">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Keyword}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                    <Button Background="Transparent" BorderBrush="Transparent" Click="OnEditSnippetClick" Padding="3" ToolTipService.ToolTip="{Binding Path=SnippetEditTooltip, Source={StaticResource LocBridge}}">
                                                        <FontIcon Glyph="&#xE70F;" FontSize="10"/>
                                                    </Button>
                                                    <Button Background="Transparent" BorderBrush="Transparent" Click="OnDeleteSnippetClick" Tag="{Binding Title}" Padding="3" ToolTipService.ToolTip="{Binding Path=SnippetDeleteTooltip, Source={StaticResource LocBridge}}">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="10"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <StackPanel Grid.Row="2" Margin="10,10,10,0" Spacing="8">
                                    <Button x:Name="AddSnippetButton" Content="스니펫 추가..." HorizontalAlignment="Stretch" Click="OnAddSnippetClick" Style="{StaticResource AccentButtonStyle}"/>
                                    <Button x:Name="AutocompleteDictButton" Content="자동완성 사전..." HorizontalAlignment="Stretch" Click="OnAutocompleteDictClick" FontSize="11"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ExportSnippetsButton" Grid.Column="0" Content="내보내기" Click="OnExportSnippetsClick" HorizontalAlignment="Stretch" FontSize="11"/>
                                        <Button x:Name="ImportSnippetsButton" Grid.Column="1" Content="가져오기" Click="OnImportSnippetsClick" HorizontalAlignment="Stretch" FontSize="11"/>
                                    </Grid>
                                    <Button x:Name="ResetSnippetsButton" Content="초기화" Click="OnResetSnippetsClick" HorizontalAlignment="Stretch" FontSize="11"/>
                                </StackPanel>
                        </Grid>

                        <!-- Tab 7: TOC (Table of Contents) Outline -->
                        <Grid x:Name="TocSidebarPage" Padding="0,10,0,10" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TocHeaderText" Grid.Row="0" Text="목차 (TOC)" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="10,0,0,10"/>
                            <ListView x:Name="TocListView" Grid.Row="1" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="OnTocItemClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayText}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="{Binding Margin}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LineDisplay}" FontSize="10" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Grid>
</UserControl>
