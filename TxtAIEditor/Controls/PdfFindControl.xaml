<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TxtAIEditor.Controls.PdfFindControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource SidebarBackgroundBrush}"
            BorderBrush="{ThemeResource SidebarBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6,4,6,4"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,10,24,0"
            Width="360"
            Height="38">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
            <!-- Search TextBox -->
            <TextBox x:Name="FindTextBox"
                     Grid.Column="0"
                     Height="28"
                     PlaceholderText="찾기"
                     VerticalAlignment="Center"
                     TextChanged="OnFindTextChanged"
                     KeyDown="OnFindTextBoxKeyDown"
                     Margin="0,0,4,0"/>

            <!-- Match Case Toggle -->
            <ToggleButton x:Name="MatchCaseButton"
                          Grid.Column="1"
                          Width="28"
                          Height="28"
                          Padding="0"
                          Margin="0,0,4,0"
                          ToolTipService.ToolTip="대소문자 구분 (Aa)"
                          Click="OnMatchCaseClick"
                          Background="Transparent"
                          BorderThickness="0"
                          CornerRadius="4"
                          VerticalAlignment="Center">
                <ToggleButton.Resources>
                    <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#15808080"/>
                    <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#30808080"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#0078D4"/>
                    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="White"/>
                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#106EBE"/>
                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#005A9E"/>
                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="White"/>
                </ToggleButton.Resources>
                <TextBlock Text="Aa" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </ToggleButton>

            <!-- Status Text -->
            <TextBlock x:Name="StatusText"
                       Grid.Column="2"
                       Text="0/0"
                       FontSize="11"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       Margin="4,0,8,0"
                       MinWidth="32"/>

            <!-- Previous Button -->
            <Button x:Name="PrevButton"
                    Grid.Column="3"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="0,0,2,0"
                    ToolTipService.ToolTip="이전"
                    Click="OnPrevClick"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="4"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15808080"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#30808080"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                </Button.Resources>
                <FontIcon Glyph="&#xE74A;" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <!-- Next Button -->
            <Button x:Name="NextButton"
                    Grid.Column="4"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="0,0,4,0"
                    ToolTipService.ToolTip="다음"
                    Click="OnNextClick"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="4"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15808080"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#30808080"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                </Button.Resources>
                <FontIcon Glyph="&#xE74B;" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <!-- Close Button -->
            <Button x:Name="CloseButton"
                    Grid.Column="5"
                    Width="28"
                    Height="28"
                    Padding="0"
                    ToolTipService.ToolTip="닫기"
                    Click="OnCloseClick"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="4"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15808080"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#30808080"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                </Button.Resources>
                <FontIcon Glyph="&#xE711;" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
