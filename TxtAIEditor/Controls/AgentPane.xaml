<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TxtAIEditor.Controls.AgentPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TxtAIEditor.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AgentButtonBackground" Color="#FCFCFC"/>
                    <SolidColorBrush x:Key="AgentButtonBorderBrush" Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="AgentOutputBackground" Color="#FCFCFC"/>
                    <SolidColorBrush x:Key="AgentOutputForeground" Color="#1F2937"/>
                    <SolidColorBrush x:Key="AgentCodeBackground" Color="#EAEAEA"/>
                    <SolidColorBrush x:Key="AgentCodeForeground" Color="#C7254E"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AgentButtonBackground" Color="#2B2D31"/>
                    <SolidColorBrush x:Key="AgentButtonBorderBrush" Color="#2E3033"/>
                    <SolidColorBrush x:Key="AgentOutputBackground" Color="#151618"/>
                    <SolidColorBrush x:Key="AgentOutputForeground" Color="#D4D4D4"/>
                    <SolidColorBrush x:Key="AgentCodeBackground" Color="#252526"/>
                    <SolidColorBrush x:Key="AgentCodeForeground" Color="#DCDCAA"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="AgentButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AgentButtonBackground}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource AgentButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,4,10,4"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Padding="15" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="AgentNewSessionButton"
                    Grid.Column="0"
                    Content="새 세션"
                    HorizontalAlignment="Stretch"
                    Click="OnNewSessionClick"
                    Style="{StaticResource AgentButtonStyle}"/>
            <Button x:Name="AgentHistoryButton"
                    Grid.Column="1"
                    Width="36"
                    Height="32"
                    Padding="0"
                    ToolTipService.ToolTip="세션 히스토리"
                    Style="{StaticResource AgentButtonStyle}">
                <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                <Button.Flyout>
                    <Flyout x:Name="AgentHistoryFlyout" Opened="OnAgentHistoryFlyoutOpened">
                        <Grid Width="280" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="AgentHistoryTitleText" Text="세션 히스토리 (최근 20개)" FontWeight="SemiBold" FontSize="12" Grid.Row="0"/>
                            <ScrollViewer Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="AgentHistoryListPanel" Spacing="4"/>
                            </ScrollViewer>
                        </Grid>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button x:Name="AgentDeleteHistoryButton"
                    Grid.Column="2"
                    Width="36"
                    Height="32"
                    Padding="0"
                    Click="OnDeleteHistoryClick"
                    ToolTipService.ToolTip="히스토리 삭제"
                    Style="{StaticResource AgentButtonStyle}">
                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
            </Button>
            <TextBlock x:Name="AgentTokenCountText"
                       Grid.Column="3"
                       Text="0.0k tokens"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      x:Name="AgentOutputScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="{ThemeResource AgentOutputBackground}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      Padding="10"
                      CornerRadius="4"
                      ViewChanged="OnAgentOutputScrollViewerViewChanged">
            <RichTextBlock x:Name="AgentOutputText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="{ThemeResource AgentOutputForeground}"
                           IsTextSelectionEnabled="True"
                           Padding="0"
                           DoubleTapped="OnOutputDoubleTapped"
                           KeyDown="OnOutputTextKeyDown"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <CheckBox x:Name="AgentStreamToTabCheckBox"
                      Content="탭에 스트리밍"
                      IsChecked="False"
                      VerticalAlignment="Center"/>
            <Button x:Name="AgentInsertOutputButton"
                    Content="입력"
                    HorizontalAlignment="Stretch"
                    Height="32"
                    Click="OnInsertOutputClick"
                    ToolTipService.ToolTip="Agent 응답을 현재 커서에 입력"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button x:Name="AgentInsertNewTabOutputButton"
                    HorizontalAlignment="Stretch"
                    Height="32"
                    Click="OnInsertNewTabOutputClick"
                    Style="{StaticResource AgentButtonStyle}"/>
        </StackPanel>

        <Border Grid.Row="3" Background="{ThemeResource ToolbarBackgroundBrush}" Padding="6" CornerRadius="4">
            <Grid RowSpacing="4" ColumnSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AgentContextStatsText"
                                   Text="현재 탭과 선택 영역을 맥락으로 사용"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <CheckBox x:Name="AgentPlanningModeCheckBox"
                              Content="계획 모드 (Planning mode)"
                              IsChecked="False"
                              FontSize="12"/>
                </StackPanel>

                <Button x:Name="AgentAddAttachmentButton"
                        Grid.Row="0"
                        Grid.Column="1"
                        Width="30"
                        Height="30"
                        Padding="0"
                        VerticalAlignment="Top"
                        Click="OnAddAttachmentClick"
                        ToolTipService.ToolTip="이미지 또는 파일 추가"
                        Style="{StaticResource AgentButtonStyle}">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                </Button>


                <ListView x:Name="AgentAttachmentsList"
                          Grid.Row="1"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          MaxHeight="96"
                          SelectionMode="None"
                          Visibility="Collapsed"
                          Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="MinHeight" Value="30"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:AgentAttachmentItem">
                            <Grid ColumnSpacing="6" Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="{Binding IconGlyph}"
                                          FontSize="12"
                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                          VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"/>
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TokenText}"
                                           FontSize="10"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="3"
                                        Tag="{Binding}"
                                        Click="OnRemoveAttachmentClick"
                                        Width="24"
                                        Height="24"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="{Binding RemoveTooltip}">
                                    <FontIcon Glyph="&#xE10A;" FontSize="10"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <StackPanel x:Name="AgentReviewPanelsHost"
                    Grid.Row="4"
                    Spacing="12"
                    Visibility="Collapsed">
            <Border x:Name="AgentDiffConfirmPanel"
                    Background="{ThemeResource ToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="10"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="AgentDiffConfirmHeader"
                               Text="파일 변경 확인"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                    <TextBlock x:Name="AgentDiffConfirmDescription"
                               Text="파일을 수정하시겠습니까?"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Border x:Name="AgentPowerShellCommandPanel"
                            Background="{ThemeResource AgentOutputBackground}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="8,4"
                            CornerRadius="4"
                            Visibility="Collapsed">
                        <ScrollViewer MaxHeight="72"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock x:Name="AgentPowerShellConfirmCommand"
                                       FontSize="11"
                                       FontFamily="Consolas, Cascadia Mono, Segoe UI, Malgun Gothic"
                                       LineHeight="16"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       Foreground="{ThemeResource AgentOutputForeground}"/>
                        </ScrollViewer>
                    </Border>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AgentDiffApproveButton"
                                Grid.Column="0"
                                Content="승인"
                                HorizontalAlignment="Stretch"
                                Height="28"
                                FontSize="11"
                                Click="OnDiffApproveClick"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <Button x:Name="AgentDiffCancelButton"
                                Grid.Column="1"
                                Content="취소"
                                HorizontalAlignment="Stretch"
                                Height="28"
                                FontSize="11"
                                Click="OnDiffCancelClick"
                                Style="{StaticResource AgentButtonStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border x:Name="AgentModifiedFilesPanel"
                    Background="{ThemeResource ToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="10"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="AgentModifiedFilesHeader"
                                       Text="변경됨 (클릭 시 비교)"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                            <TextBlock x:Name="AgentModifiedFilesDescription"
                                       Text="수정된 파일 목록입니다. 되돌리려면 우측 아이콘을 클릭하세요."
                                       FontSize="11"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="AgentModifiedFilesCloseButton"
                                Click="OnModifiedFilesCloseClick"
                                Width="24"
                                Height="24"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Top"
                                ToolTipService.ToolTip="목록 닫기">
                            <FontIcon Glyph="&#xE10A;" FontSize="11"/>
                        </Button>
                    </Grid>
                    
                    <ListView x:Name="AgentModifiedFilesList"
                              Grid.Row="1"
                              MinHeight="60"
                              MaxHeight="150"
                              Margin="0,4,0,0"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="OnModifiedFilesListItemClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="MinHeight" Value="32"/>
                                <Setter Property="Padding" Value="4,2,4,2"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AgentFileEditPreview">
                                <Grid HorizontalAlignment="Stretch" Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding RelativePath}" 
                                                   FontSize="11" 
                                                   TextWrapping="NoWrap" 
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Click="OnRevertFileClick"
                                            Tag="{Binding}"
                                            Width="24"
                                            Height="24"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTipService.ToolTip="이 파일의 변경 취소">
                                        <FontIcon Glyph="&#xE7A7;" FontSize="11"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="5" ColumnSpacing="8" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer x:Name="AgentSelectedPresetScrollViewer"
                          Grid.Row="0" Grid.Column="0"
                          Margin="0,0,0,4"
                          HorizontalScrollMode="Auto"
                          VerticalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden"
                          Visibility="Collapsed">
                <StackPanel x:Name="AgentSelectedPresetPanel"
                            Orientation="Horizontal"
                            Spacing="4"/>
            </ScrollViewer>
            <Grid Grid.Row="1" Grid.Column="0">
                <TextBox x:Name="AgentPromptInput"
                         PlaceholderText="Agent에게 맡길 작업 입력..."
                         MinHeight="72"
                         MaxHeight="120"
                         FontSize="12"
                         FontFamily="Segoe UI, Malgun Gothic"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Padding="10,8,26,8"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         IsSpellCheckEnabled="False"
                         IsTextPredictionEnabled="False"
                         KeyDown="OnPromptInputKeyDown"
                         TextChanged="OnPromptTextChanged">
                    <TextBox.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter"
                                             Modifiers="Control"
                                             Invoked="OnPromptRunKeyboardAcceleratorInvoked"/>
                    </TextBox.KeyboardAccelerators>
                </TextBox>
                  <Button x:Name="AgentClearPromptButton"
                          Width="20" Height="20"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="0,6,6,0"
                          FontSize="10"
                          Padding="2"
                          Visibility="Collapsed"
                          Click="OnClearPromptClick"
                          Style="{StaticResource AgentButtonStyle}">
                      <FontIcon Glyph="&#xE10A;" FontSize="10"/>
                  </Button>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="1"
                  Width="68"
                  ColumnSpacing="4"
                  RowSpacing="4"
                  VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="AgentSkillButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MinHeight="0"
                        Padding="0"
                        Style="{StaticResource AgentButtonStyle}">
                    <FontIcon Glyph="&#xE82D;" FontSize="14"/>
                    <Button.Flyout>
                        <Flyout x:Name="AgentSkillFlyout" Opened="OnAgentSkillFlyoutOpened">
                            <Grid Width="240" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="AgentSkillTitleText"
                                           Grid.Row="0"
                                           Text="스킬"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                                <MenuFlyoutSeparator Grid.Row="1"/>
                                <ScrollViewer Grid.Row="2" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="AgentSkillListPanel" Spacing="4"/>
                                </ScrollViewer>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="AgentPresetButton"
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MinHeight="0"
                        Padding="0"
                        FontSize="14"
                        Style="{StaticResource AgentButtonStyle}">
                    <FontIcon Glyph="&#xE109;" FontSize="16"/>
                    <Button.Flyout>
                        <Flyout x:Name="AgentPresetFlyout" Opened="OnAgentPresetFlyoutOpened">
                            <Grid Width="220" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button x:Name="AgentAddPresetButton"
                                        Grid.Row="0"
                                        HorizontalAlignment="Stretch"
                                        Click="OnAgentAddPresetClickInPanel"
                                        Style="{StaticResource AgentButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE109;" FontSize="12"/>
                                        <TextBlock x:Name="AgentAddPresetText" Text="프리셋 추가" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="AgentExportPresetButton"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            Click="OnAgentExportPresetClickInPanel"
                                            Style="{StaticResource AgentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE118;" FontSize="12"/>
                                            <TextBlock x:Name="AgentExportPresetText" Text="내보내기" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="AgentImportPresetButton"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Click="OnAgentImportPresetClickInPanel"
                                            Style="{StaticResource AgentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE8B5;" FontSize="12"/>
                                            <TextBlock x:Name="AgentImportPresetText" Text="가져오기" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <MenuFlyoutSeparator Grid.Row="2"/>
                                <ScrollViewer Grid.Row="3" MaxHeight="250" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="AgentPresetListPanel" Spacing="4"/>
                                </ScrollViewer>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="AgentRunButton"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Content="실행"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MinHeight="0"
                        Padding="0"
                        Click="OnRunClick"
                        Style="{StaticResource AccentButtonStyle}"/>
            </Grid>
            <HyperlinkButton x:Name="AgentModelNameButton"
                             Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                             Padding="0"
                             MinHeight="0"
                             MinWidth="0"
                             Margin="2,1,0,-12"
                             Click="OnModelNameClick">
                <TextBlock x:Name="AgentModelNameText"
                           FontSize="11"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </HyperlinkButton>
        </Grid>

        <Border x:Name="AgentActivityPanel"
                Grid.Row="6"
                Background="{ThemeResource ToolbarBackgroundBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Visibility="Collapsed">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="AgentActivityHeaderText"
                           Text="진행 상황"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="AgentActivityText"
                         Grid.Row="1"
                         Text="대기 중"
                         MaxHeight="88"
                         FontSize="11"
                         FontFamily="Consolas, Cascadia Mono, Segoe UI, Malgun Gothic"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
