<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TxtAIEditor.Controls.AgentPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AgentButtonBackground" Color="#FCFCFC"/>
                    <SolidColorBrush x:Key="AgentButtonBorderBrush" Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="AgentOutputBackground" Color="#FCFCFC"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AgentButtonBackground" Color="#2B2D31"/>
                    <SolidColorBrush x:Key="AgentButtonBorderBrush" Color="#2E3033"/>
                    <SolidColorBrush x:Key="AgentOutputBackground" Color="#151618"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="AgentButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AgentButtonBackground}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource AgentButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,4,10,4"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Padding="15" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="AgentNewSessionButton"
                    Grid.Column="0"
                    Content="새 세션"
                    HorizontalAlignment="Stretch"
                    Click="OnNewSessionClick"
                    Style="{StaticResource AgentButtonStyle}"/>
            <TextBlock x:Name="AgentTokenCountText"
                       Grid.Column="1"
                       Text="0.0k tokens"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="{ThemeResource AgentOutputBackground}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      Padding="10"
                      CornerRadius="4">
            <TextBox x:Name="AgentOutputText"
                     Text="대기 중... Agent에게 작업을 지시해 보세요."
                     TextWrapping="Wrap"
                     FontSize="13"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="0"
                     AcceptsReturn="True"/>
        </ScrollViewer>

        <Button x:Name="AgentInsertOutputButton"
                Grid.Row="2"
                Content="입력"
                HorizontalAlignment="Stretch"
                Height="32"
                Click="OnInsertOutputClick"
                ToolTipService.ToolTip="Agent 응답을 현재 커서에 입력"
                Style="{StaticResource AccentButtonStyle}"/>

        <Border Grid.Row="3" Background="{ThemeResource ToolbarBackgroundBrush}" Padding="8" CornerRadius="4">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE946;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AgentContextStatsText"
                               Text="현재 탭과 선택 영역을 맥락으로 사용"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <CheckBox x:Name="AgentIncludeActiveFileCheckBox"
                          Content="현재 탭 포함"
                          IsChecked="False"
                          FontSize="12"/>
            </StackPanel>
        </Border>

        <Border x:Name="AgentDiffConfirmPanel"
                Grid.Row="4"
                Background="{ThemeResource ToolbarBackgroundBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="10"
                CornerRadius="4"
                Visibility="Collapsed">
            <StackPanel Spacing="10">
                <TextBlock x:Name="AgentDiffConfirmHeader"
                           Text="파일 변경 확인"
                           FontWeight="SemiBold"
                           FontSize="12"/>
                <TextBlock x:Name="AgentDiffConfirmDescription"
                           Text="파일을 수정하시겠습니까?"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AgentDiffApproveButton"
                            Grid.Column="0"
                            Content="승인"
                            HorizontalAlignment="Stretch"
                            Height="28"
                            FontSize="11"
                            Click="OnDiffApproveClick"
                            Style="{StaticResource AccentButtonStyle}"/>
                    <Button x:Name="AgentDiffCancelButton"
                            Grid.Column="1"
                            Content="취소"
                            HorizontalAlignment="Stretch"
                            Height="28"
                            FontSize="11"
                            Click="OnDiffCancelClick"
                            Style="{StaticResource AgentButtonStyle}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="5" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="AgentPromptInput"
                     Grid.Column="0"
                     PlaceholderText="Agent에게 맡길 작업 입력..."
                     MinHeight="72"
                     MaxHeight="120"
                     FontSize="12"
                     FontFamily="Segoe UI, Malgun Gothic"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="10,8,10,8"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     IsSpellCheckEnabled="False"
                     IsTextPredictionEnabled="False"
                     KeyDown="OnPromptInputKeyDown">
                <TextBox.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter"
                                         Modifiers="Control"
                                         Invoked="OnPromptRunKeyboardAcceleratorInvoked"/>
                </TextBox.KeyboardAccelerators>
            </TextBox>
            <Button x:Name="AgentRunButton"
                    Grid.Column="1"
                    Content="실행"
                    Width="64"
                    VerticalAlignment="Stretch"
                    Click="OnRunClick"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <Border x:Name="AgentActivityPanel"
                Grid.Row="6"
                Background="{ThemeResource ToolbarBackgroundBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Visibility="Collapsed">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="AgentActivityHeaderText"
                           Text="진행 상황"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="AgentActivityText"
                         Grid.Row="1"
                         Text="대기 중"
                         MaxHeight="88"
                         FontSize="11"
                         FontFamily="Consolas, Cascadia Mono, Segoe UI, Malgun Gothic"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
