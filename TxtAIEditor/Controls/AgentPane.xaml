<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TxtAIEditor.Controls.AgentPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TxtAIEditor.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AgentButtonBackground" Color="#FCFCFC"/>
                    <SolidColorBrush x:Key="AgentButtonBorderBrush" Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="AgentOutputBackground" Color="#FCFCFC"/>
                    <SolidColorBrush x:Key="AgentCodeBackground" Color="#EAEAEA"/>
                    <SolidColorBrush x:Key="AgentCodeForeground" Color="#C7254E"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AgentButtonBackground" Color="#2B2D31"/>
                    <SolidColorBrush x:Key="AgentButtonBorderBrush" Color="#2E3033"/>
                    <SolidColorBrush x:Key="AgentOutputBackground" Color="#151618"/>
                    <SolidColorBrush x:Key="AgentCodeBackground" Color="#2D3139"/>
                    <SolidColorBrush x:Key="AgentCodeForeground" Color="#E06C75"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="AgentButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AgentButtonBackground}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource AgentButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,4,10,4"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Padding="15" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="AgentNewSessionButton"
                    Grid.Column="0"
                    Content="새 세션"
                    HorizontalAlignment="Stretch"
                    Click="OnNewSessionClick"
                    Style="{StaticResource AgentButtonStyle}"/>
            <TextBlock x:Name="AgentTokenCountText"
                       Grid.Column="1"
                       Text="0.0k tokens"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      x:Name="AgentOutputScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="{ThemeResource AgentOutputBackground}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      Padding="10"
                      CornerRadius="4">
            <RichTextBlock x:Name="AgentOutputText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           IsTextSelectionEnabled="True"
                           Padding="0"
                           KeyDown="OnOutputTextKeyDown"/>
        </ScrollViewer>

        <Button x:Name="AgentInsertOutputButton"
                Grid.Row="2"
                Content="입력"
                HorizontalAlignment="Stretch"
                Height="32"
                Click="OnInsertOutputClick"
                ToolTipService.ToolTip="Agent 응답을 현재 커서에 입력"
                Style="{StaticResource AccentButtonStyle}"/>

        <Border Grid.Row="3" Background="{ThemeResource ToolbarBackgroundBrush}" Padding="8" CornerRadius="4">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE946;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AgentContextStatsText"
                               Text="현재 탭과 선택 영역을 맥락으로 사용"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <CheckBox x:Name="AgentIncludeActiveFileCheckBox"
                          Content="현재 탭 포함"
                          IsChecked="False"
                          FontSize="12"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Spacing="12">
            <Border x:Name="AgentDiffConfirmPanel"
                    Background="{ThemeResource ToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="10"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="AgentDiffConfirmHeader"
                               Text="파일 변경 확인"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                    <TextBlock x:Name="AgentDiffConfirmDescription"
                               Text="파일을 수정하시겠습니까?"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AgentDiffApproveButton"
                                Grid.Column="0"
                                Content="승인"
                                HorizontalAlignment="Stretch"
                                Height="28"
                                FontSize="11"
                                Click="OnDiffApproveClick"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <Button x:Name="AgentDiffCancelButton"
                                Grid.Column="1"
                                Content="취소"
                                HorizontalAlignment="Stretch"
                                Height="28"
                                FontSize="11"
                                Click="OnDiffCancelClick"
                                Style="{StaticResource AgentButtonStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border x:Name="AgentModifiedFilesPanel"
                    Background="{ThemeResource ToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="10"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="AgentModifiedFilesHeader"
                                       Text="변경됨 (더블클릭 시 비교)"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                            <TextBlock x:Name="AgentModifiedFilesDescription"
                                       Text="수정된 파일 목록입니다. 되돌리려면 우측 아이콘을 클릭하세요."
                                       FontSize="11"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="AgentModifiedFilesCloseButton"
                                Click="OnModifiedFilesCloseClick"
                                Width="24"
                                Height="24"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Top"
                                ToolTipService.ToolTip="목록 닫기">
                            <FontIcon Glyph="&#xE10A;" FontSize="11"/>
                        </Button>
                    </Grid>
                    
                    <ListView x:Name="AgentModifiedFilesList"
                              Grid.Row="1"
                              MinHeight="60"
                              MaxHeight="150"
                              Margin="0,4,0,0"
                              SelectionMode="Single"
                              DoubleTapped="OnModifiedFilesListDoubleTapped">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="MinHeight" Value="32"/>
                                <Setter Property="Padding" Value="4,2,4,2"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AgentFileEditPreview">
                                <Grid HorizontalAlignment="Stretch" Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding RelativePath}" 
                                                   FontSize="11" 
                                                   TextWrapping="NoWrap" 
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Click="OnRevertFileClick"
                                            Tag="{Binding}"
                                            Width="24"
                                            Height="24"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTipService.ToolTip="이 파일의 변경 취소">
                                        <FontIcon Glyph="&#xE7A7;" FontSize="11"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="5" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="AgentPromptInput"
                     Grid.Column="0"
                     PlaceholderText="Agent에게 맡길 작업 입력..."
                     MinHeight="72"
                     MaxHeight="120"
                     FontSize="12"
                     FontFamily="Segoe UI, Malgun Gothic"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="10,8,10,8"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     IsSpellCheckEnabled="False"
                     IsTextPredictionEnabled="False"
                     KeyDown="OnPromptInputKeyDown">
                <TextBox.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter"
                                         Modifiers="Control"
                                         Invoked="OnPromptRunKeyboardAcceleratorInvoked"/>
                </TextBox.KeyboardAccelerators>
            </TextBox>
            <Button x:Name="AgentRunButton"
                    Grid.Column="1"
                    Content="실행"
                    Width="64"
                    VerticalAlignment="Stretch"
                    Click="OnRunClick"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <Border x:Name="AgentActivityPanel"
                Grid.Row="6"
                Background="{ThemeResource ToolbarBackgroundBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="8"
                CornerRadius="4"
                Visibility="Collapsed">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="AgentActivityHeaderText"
                           Text="진행 상황"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <TextBox x:Name="AgentActivityText"
                         Grid.Row="1"
                         Text="대기 중"
                         MaxHeight="88"
                         FontSize="11"
                         FontFamily="Consolas, Cascadia Mono, Segoe UI, Malgun Gothic"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
