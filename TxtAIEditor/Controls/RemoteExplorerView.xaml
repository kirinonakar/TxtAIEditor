<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TxtAIEditor.Controls.RemoteExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Width="280" MinWidth="200" MaxHeight="520">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="4,2,4,10" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="리모트 서버" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock x:Name="DescriptionText"
                           Text="WSL, SSH/SFTP, FTPS, WebDAV"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="AddServerButton"
                    Grid.Column="1"
                    Click="OnAddServerClick"
                    Padding="10,6"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    <TextBlock x:Name="AddServerButtonText" Text="서버 추가"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid x:Name="ServerListPanel" Grid.Row="1" MinHeight="96">
            <ListView x:Name="ServerList"
                      MaxHeight="360"
                      IsItemClickEnabled="True"
                      ItemClick="OnServerItemClick"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="54" Padding="8,4" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE774;" FontSize="18" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Summary}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Click="OnDeleteServerClick"
                                    Tag="{Binding}"
                                    Visibility="{Binding DeleteVisibility}"
                                    Padding="8"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel x:Name="EmptyServersPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsHitTestVisible="False">
                <FontIcon Glyph="&#xE774;" FontSize="30" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="EmptyServersText"
                           Text="추가된 서버가 없습니다."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="BrowserPanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,8" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="RemoteUpButton" Click="OnRemoteUpClick" Padding="8">
                    <FontIcon Glyph="&#xE74A;" FontSize="11"/>
                </Button>
                <StackPanel Grid.Column="1" Margin="4,0" VerticalAlignment="Center">
                    <TextBlock x:Name="ConnectedServerText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="CurrentPathText" FontSize="10"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button x:Name="RemoteRefreshButton" Grid.Column="2" Click="OnRemoteRefreshClick" Padding="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="11"/>
                </Button>
                <Button x:Name="DisconnectButton" Grid.Column="3" Click="OnDisconnectClick" Padding="8">
                    <FontIcon Glyph="&#xE8BB;" FontSize="11"/>
                </Button>
            </Grid>

            <InfoBar x:Name="ProtocolInfoBar"
                     Grid.Row="1"
                     IsOpen="False"
                     Severity="Informational"
                     IsClosable="False"
                     Margin="0,0,0,6"/>

            <ListView x:Name="RemoteEntryList"
                      Grid.Row="2"
                      IsItemClickEnabled="True"
                      ItemClick="OnRemoteEntryClick"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="42" Padding="8,3" ColumnSpacing="9">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Name="RemoteEntryDownloadMenuItem" Text="다운로드" Click="OnRemoteEntryDownloadClick" Tag="{Binding}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{Binding IconGlyph}" FontSize="14" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="10"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="2" Margin="4,8,4,2">
            <TextBlock x:Name="StatusText"
                       Text="서버를 선택하세요."
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <ProgressRing x:Name="BusyRing"
                          Width="20"
                          Height="20"
                          HorizontalAlignment="Right"
                          IsActive="False"
                          Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
